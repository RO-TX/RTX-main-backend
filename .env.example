# ─────────────────────────────────────────────────────────────
# RTX Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────

# Core
NODE_ENV=development
PORT=5000

# Comma-separated list of allowed frontend origins (user site + admin dashboard)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# MongoDB connection string (DB name embedded in the URI)
MONGODB_URI=mongodb://127.0.0.1:27017/rtx
# Optional cloud DB (MongoDB Atlas) — kept for future; copy into MONGODB_URI to use
MONGODB_ATLAS_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/rtx?retryWrites=true&w=majority

# ── Auth / JWT ──
# Use long random strings. Generate: openssl rand -hex 48
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
# Set to your apex domain in prod (e.g. .rotechnicalxperts.com) so the
# refresh cookie is shared between app. and admin. subdomains. Leave blank in dev.
COOKIE_DOMAIN=

# ── Email (SMTP / nodemailer) ──
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_AUTH=your_smtp_user
MAIL_PASS=your_smtp_password
MAIL_FROM="RO Technical Xperts <no-reply@rotechnicalxperts.com>"

# ── Razorpay ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Cloudinary ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=rtx

# ── Delhivery (shipping) ──
DELHIVERY_API_KEY=
DELHIVERY_ENVIRONMENT=staging
MOCK_SHIPPING_ENABLED=true

# ── AI Chatbot (Groq via OpenAI SDK) ──
GROQ_API_KEY=

# ── AWS S3 (file/image storage) ──
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Company / misc ──
COMPANY_NAME=RO Technical Xperts
SUPPORT_PHONE=+91-8810294546
